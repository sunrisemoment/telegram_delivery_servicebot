# Copy this file to `.env.prod` and replace the placeholder values.

# Public application URLs
API_PUBLISH_PORT=8000
API_BASE_URL=https://your-domain.example
MINI_APP_URL=https://your-domain.example/miniapp
BOT_WEBHOOK_URL=https://your-domain.example
WEBHOOK_URL=https://your-domain.example/webhook/btc-payment

# Telegram
TELEGRAM_BOT_TOKEN=

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=replace-with-a-long-random-secret
MINI_APP_SESSION_TTL_HOURS=24
MINI_APP_INIT_DATA_MAX_AGE_SECONDS=86400

# Database
POSTGRES_DB=deliver
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
# The production compose file overrides DATABASE_URL to use the internal `db` host.
DATABASE_URL=postgresql://postgres:change-me@db:5432/deliver

# BTC / payments
ACCEPT_ZERO_CONF=true
ALLOW_RBF=false
MIN_AMOUNT_TOLERANCE=50
DELIVERY_LEAD_MINUTES=20
DELIVERY_MINIMUM_CENTS=10000
BTC_WATCHER=btcpay
BTC_XPUB=
BTC_STATIC_ADDRESS=

# Admin
ADMIN_CHAT_ID=
DAILY_CSV_CHANNEL_ID=
ADMIN_USER_IDS=
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Timezone
SITE_TZ=America/New_York

# Delivery
DEFAULT_CITY=NewYork
BASE_DELIVERY_FEE=1000
OUTSIDE_CITY_DELIVERY_FEE=2000

# BTC Payment Configuration
BLOCKCYPHER_API_KEY=
BTC_WEBHOOK_SECRET=
BTC_SEED=

GOOGLE_MAPS_API_KEY=your_key_here
